{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CIIUTI Test Config Schema",
  "type": "object",
  "required": [
    "meta",
    "dimensions",
    "roles",
    "questions",
    "scoring"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["testId", "title", "version", "locale"],
      "properties": {
        "testId": { "type": "string" },
        "title": { "type": "string" },
        "version": { "type": "string" },
        "locale": { "type": "string" },
        "resultCount": { "type": "integer", "minimum": 2 }
      }
    },
    "dimensions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "weight"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "weight": { "type": "number", "minimum": 0 }
        }
      }
    },
    "roles": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["id", "name", "archetypeVector", "copy"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "archetypeVector": {
            "type": "object",
            "additionalProperties": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            }
          },
          "copy": {
            "type": "object",
            "required": ["slogan", "teaser", "advice"],
            "properties": {
              "slogan": { "type": "string" },
              "teaser": { "type": "string" },
              "advice": { "type": "string" }
            }
          }
        }
      }
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "dimensionId",
          "text",
          "reverseScored",
          "options"
        ],
        "properties": {
          "id": { "type": "string" },
          "dimensionId": { "type": "string" },
          "text": { "type": "string" },
          "reverseScored": { "type": "boolean" },
          "options": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": ["id", "label", "score"],
              "properties": {
                "id": { "type": "string" },
                "label": { "type": "string" },
                "score": { "type": "integer", "minimum": 1, "maximum": 5 }
              }
            }
          }
        }
      }
    },
    "scoring": {
      "type": "object",
      "required": ["method", "confidenceThreshold"],
      "properties": {
        "method": {
          "type": "string",
          "enum": ["weighted_manhattan", "weighted_euclidean"]
        },
        "confidenceThreshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "qualityGuard": {
          "type": "object",
          "properties": {
            "maxSingleChoiceRatio": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "minDurationSeconds": { "type": "number", "minimum": 0 }
          }
        }
      }
    }
  }
}
